rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened security helper primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidChat(chat) {
      return chat.id is string && chat.id.size() <= 128
        && chat.userId is string && chat.userId.size() <= 128
        && chat.title is string && chat.title.size() <= 200
        && chat.symbol is string && chat.symbol.size() <= 20
        && chat.messages is list && chat.messages.size() <= 200;
    }

    // Secure rule declarations for Chats collection
    match /chats/{chatId} {
      allow get, delete: if isSignedIn() && isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && isOwner(request.resource.data.userId)
        && isValidId(chatId)
        && isValidChat(request.resource.data)
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
      allow update: if isSignedIn()
        && isOwner(resource.data.userId)
        && isOwner(request.resource.data.userId)
        && isValidChat(request.resource.data)
        && request.resource.data.updatedAt is string;
    }

    // Secure rule declarations for Funding collection
    match /funding/{userId} {
      allow get, write: if isSignedIn() && isOwner(userId);
    }

    // Secure rule declarations for Breaches collection
    match /breaches/{userId} {
      allow get, write: if isSignedIn() && isOwner(userId);
    }

    // Secure rule declarations for Watchlists collection
    match /watchlists/{userId} {
      allow get, write: if isSignedIn() && isOwner(userId);
    }
  }
}
